# XVRYTHNG Backend - Copy to .env and set values
# Never commit .env to version control.

NODE_ENV=development
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=xvrythng
DB_PASSWORD=your_password
DB_NAME=xvrythng

# JWT - Use long random strings in production (e.g. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=gmail account
SMTP_PASS=gmail app password
SMTP_FROM="XVRYTHNG <no-reply@xvrythng.com>"

# Resend (customer portal link + OTP emails). Get key at https://resend.com/api-keys
# With onboarding@resend.dev you can only send TO the email you signed up with. Verify a domain to send to any address.
RESEND_API_KEY=re_DKejvtp9_EJQjuawVQRF8qUkBt5b65Sx5
RESEND_FROM="XVRYTHNG <onboarding@resend.dev>"
PORTAL_BASE_URL=http://localhost:5173
