# XVRYTHNG Backend - Copy to .env and set values
# Never commit .env to version control.

NODE_ENV=development
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=xvrythng
DB_PASSWORD=your_password
DB_NAME=xvrythng

# JWT - Use long random strings in production (e.g. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

RESEND_API_KEY=git

RESEND_FROM="XVRYTHNG <onboarding@resend.dev>"


FU_FIRST_DELAY_MINUTES=2
FU_SECOND_DELAY_MINUTES=2
FOLLOWUP_SWEEP_INTERVAL_MS=60000
FU_CLOSE_AFTER_SECOND_MINUTES=2



OWNER_DOC_ADMIN_EMAIL="lenguyennhutminh4@gmail.com"
OWNER_DOC_REMINDER_SCHEDULE_MINUTES=2      # test: remind after 2’, 10’, 60’ 
OWNER_DOC_REMIND_REPEAT_LAST=true                
OWNER_DOC_REMINDER_SWEEP_INTERVAL_MS=60000  
