# XVRYTHNG Backend - Copy to .env and set values
# Never commit .env to version control.

NODE_ENV=development
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=xvrythng

# JWT - Use long random strings in production (e.g. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=8h

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=gmail account
SMTP_PASS=gmail app password
SMTP_FROM="XVRYTHNG <no-reply@xvrythng.com>"

# Resend (customer portal link + OTP emails)
RESEND_API_KEY=re_bw2wByKJ_N5tei9eHqbGhfbeKLZbpyy57
RESEND_FROM="XVRYTHNG <noreply@xvrything.com.au>"
PORTAL_BASE_URL=http://localhost:5173

FU_FIRST_DELAY_MINUTES=2
FU_SECOND_DELAY_MINUTES=2
FOLLOWUP_SWEEP_INTERVAL_MS=60000
FU_CLOSE_AFTER_SECOND_MINUTES=2

OWNER_DOC_ADMIN_EMAIL="lenguyennhutminh4@gmail.com"
OWNER_DOC_REMINDER_SCHEDULE_MINUTES=2
OWNER_DOC_REMIND_REPEAT_LAST=true
OWNER_DOC_REMINDER_SWEEP_INTERVAL_MS=60000

# Pylon (Observer) — server-side only; see https://app.getpylon.com/docs/api
